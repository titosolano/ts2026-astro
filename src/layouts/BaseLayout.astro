---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'Tito Solano | Webflow Developer, Digital Systems Designer & Creative Technologist',
  description = 'Design-driven websites, Webflow development, integrations, automation, and digital systems.',
  ogImage = '/images/titosolanoOG.jpg',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />

    <title>{title}</title>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KWR6Z8T5');</script>
    <!-- End Google Tag Manager -->

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "name": "Tito Solano — Digital Systems Designer",
        "url": "https://titosolano.com",
        "inLanguage": "en",
        "mainEntity": {
          "@type": "Person",
          "name": "Tito Solano",
          "jobTitle": "Digital Systems Designer",
          "description": "Design-led digital systems builder focused on high-end web experiences. I structure and build digital products where design, logic, and execution work together with precision.",
          "image": "https://titosolano.com/images/titosolanoOG.jpg",
          "url": "https://titosolano.com",
          "sameAs": [],
          "knowsAbout": [
            "Webflow Development",
            "Digital Systems Design",
            "UI/UX Design",
            "Web Development",
            "Design Systems",
            "Frontend Development",
            "Sanity CMS",
            "Astro",
            "GSAP Animations",
            "API Integrations",
            "Workflow Automation"
          ],
          "hasCredential": [
            {
              "@type": "EducationalOccupationalCredential",
              "name": "Client-First Certification",
              "description": "One of the first six officially certified Client-First Webflow developers"
            }
          ],
          "award": [
            "CloneComp Grand Prize Winner",
            "Webflow Speed Build Challenge Quarter-Finalist"
          ]
        },
        "about": {
          "@type": "Service",
          "serviceType": "Digital Systems Design",
          "description": "Design-led thinking, precision implementation, connected systems, and future-oriented workflows for high-end digital experiences."
        }
      }
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KWR6Z8T5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>

<script>
  // Marks html with .js so data-anim CSS can hide elements before GSAP runs
  document.documentElement.classList.add('js')

  import { initAnimations } from '../lib/animations'
  initAnimations()
</script>
