---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'Tito Solano | Webflow Developer, Digital Systems Designer & Creative Technologist',
  description = 'Design-driven websites, Webflow development, integrations, automation, and digital systems.',
  ogImage = '/images/titosolanoOG.jpg',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />

    <title>{title}</title>

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Tito Solano",
        "jobTitle": "Digital Systems Designer",
        "url": "/"
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  // Marca el html con .js para que el CSS de data-anim pueda ocultar
  // elementos antes de que GSAP corra (evita flash de contenido visible)
  document.documentElement.classList.add('js')

  import { initAnimations } from '../lib/animations'
  initAnimations()
</script>
