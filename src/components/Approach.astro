---
import SectionHeaderImage from './SectionHeaderImage.astro'
import ButtonCall from './ButtonCall.astro'

const steps = [
  {
    icon: '/images/frame.svg',
    label: 'Understand the Context',
    body: 'The best projects usually start with good questions. Before thinking about design or development, I like understanding the business, the people behind it, and what success actually looks like.',
    principle: 'Better understanding leads to better decisions.',
  },
  {
    icon: '/images/system.svg',
    label: 'Shape the Solution',
    body: 'Every project requires a different balance of design, technology, process, and execution. This stage is about defining the right direction, choosing the right tools, and shaping a solution that makes sense for the goals, the users, and the people who will use and manage it.',
    principle: 'The best solution is rarely the most complex one.',
  },
  {
    icon: '/images/precision.svg',
    label: 'Build with Precision',
    body: 'This is where ideas become real. I care deeply about implementation quality, visual refinement, usability, responsiveness, performance, and all the details that make digital experiences feel intentional.',
    principle: 'Details matter more than they seem.',
  },
  {
    icon: '/images/iterate.svg',
    label: 'Refine & Evolve',
    body: 'Digital products rarely stay still. As businesses grow and priorities change, systems need to adapt. I believe in building solutions that can evolve over time without becoming difficult to manage.',
    principle: 'Good digital products are never truly finished.',
  },
]

const principles = [
  'Design should solve a real business need.',
  'Usability comes before visual complexity.',
  'Good structure creates better user experiences.',
  'Every decision should consider the people using the product.',
  'Technology should support the business, the team, and the user.',
  'The best solutions balance design, function, and maintainability.',
  'Clear systems make websites easier to grow, manage, and improve.',
]

const expectations = [
  'Direct and honest communication.',
  'Thoughtful questions before jumping into execution.',
  'Clear recommendations based on experience.',
  'Design aligned with technical execution.',
  'Attention to detail across the entire experience.',
  'Flexible solutions built for long-term growth.',
  'A partner who understands both design and development.',
]
---

<section id="approach" class="section_approach">
  <div class="process_component">

    <SectionHeaderImage
      label="Approach"
      subtitle="Understand first. Define with intent. Build systems that scale."
      description="Successful digital projects rarely come from following a rigid process. They come from asking the right questions, making thoughtful decisions, and balancing design, technology, and business needs along the way."
      backgroundImage="/images/background-sections.avif"
    />

    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-small">
          <div class="process_mid-content">

            <!-- Row 1: 4 process steps -->
            <div class="process_list">
              {steps.map(({ icon, label, body, principle }, i) => (
                <div class="process_group">
                  <div class="process_group-content"
                    data-anim="blur-fade"
                    data-anim-delay={String(i * 0.08)}
                  >
                    <img src={icon} loading="lazy" alt="" class="icon-embed-xsmall" />
                    <div class="spacer-small"></div>
                    <h3 class="heading-style-label">{label}</h3>
                    <div class="spacer-small"></div>
                    <p>{body}</p>
                    <div class="process_principle">
                      <div class="navbar_available-dot"><div class="green-light"></div></div>
                      <span>{principle}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="process_spacer"></div>

            <!-- Row 2: Principles / How I work / Expectations -->
            <div class="process_list is-3">
              <!-- Guiding Principles -->
              <div class="process_group">
                <div class="process_group-content"
                  data-anim="blur-fade"
                >
                  <h3 class="heading-style-label">Guiding Principles</h3>
                  <div class="spacer-small"></div>
                  <ul class="dots-list-text" role="list">
                    {principles.map((p) => <li>{p}</li>)}
                  </ul>
                </div>
              </div>

              <!-- How I work -->
              <div class="process_group">
                <div class="process_group-content"
                  data-anim="blur-fade"
                  data-anim-delay="0.08"
                >
                  <h3 class="heading-style-label">How I Work</h3>
                  <div class="spacer-small"></div>
                  <p>"I enjoy collaborating with teams that care about quality, clarity, and building things the right way. My role often sits between design and development, helping turn ideas into digital experiences that are thoughtful, useful, and well executed."</p>
                  <div class="spacer-small"></div>
                  <div class="button-group">
                    <ButtonCall cta="book_call" ctaLocation="approach" ctaContext="section_cta" />
                  </div>
                </div>
              </div>

              <!-- What you can expect -->
              <div class="process_group">
                <div class="process_group-content"
                  data-anim="blur-fade"
                  data-anim-delay="0.16"
                >
                  <h3 class="heading-style-label">What You Can Expect</h3>
                  <div class="spacer-small"></div>
                  <ul class="dots-list-text" role="list">
                    {expectations.map((e) => <li>{e}</li>)}
                  </ul>
                </div>
              </div>
            </div>

          </div>
        </div>
        <div class="spacer-medium"></div>
      </div>
    </div>

  </div>
</section>
