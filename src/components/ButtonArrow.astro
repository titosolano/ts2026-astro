---
interface Props {
  href: string
  label: string
  target?: string
  variant?: 'base' | 'navbar'
}
const { href, label, target, variant = 'base' } = Astro.props
const isNavbar = variant === 'navbar'
---

<div class="button-01_component">
  <a
    href={href}
    target={target}
    rel={target === '_blank' ? 'noopener noreferrer' : undefined}
    class:list={['button-01_main-wrapper', { 'is-navbar': isNavbar }]}
  >
    <div class="button-01_text-wrapper">
      <div>{label}</div>
    </div>

    <div class="button-01_arrow-wrapper">
      <div class="button-01_arrow-position">
        <div class="button-01_arrow-img">
          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 7 14" fill="none" aria-hidden="true">
            <path d="M0.613281 0.61377L6.34059 6.75017L0.613281 12.8866" stroke="currentColor" stroke-width="1.22728" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
      <div class="button-01_arrow-position">
        <div class="button-01_arrow-img">
          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 7 14" fill="none" aria-hidden="true">
            <path d="M0.613281 0.61377L6.34059 6.75017L0.613281 12.8866" stroke="currentColor" stroke-width="1.22728" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="button-01_background"></div>
  </a>
</div>
