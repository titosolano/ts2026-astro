---
const items = [
  {
    heading: 'Design-Led Thinking',
    body: 'My background in product design, branding, and UX/UI lets me contribute before execution begins, understanding goals, user needs, and constraints to shape the right direction from the start. The best digital experiences emerge when design is informed by both business objectives and user needs.',
    thumb: '[Design-Led]',
    thumbClass: '',
  },
  {
    heading: 'Precision Implementation',
    body: 'Over ten years building digital products across industries has given me a strong appreciation for quality execution. I focus on reliable, maintainable, high-performing solutions, paying close attention to the details that shape the overall experience, regardless of platform or technology.',
    thumb: '[Precision]',
    thumbClass: 'is-2',
  },
  {
    heading: 'Connected Systems',
    body: 'Digital experiences rarely exist in isolation. I connect websites with external platforms, APIs, databases, and automations to create systems that work together, reducing friction, simplifying operations, and building solutions that are easier to manage over time.',
    thumb: '[Connected]',
    thumbClass: 'is-3',
  },
  {
    heading: 'Future-Oriented Workflows',
    body: 'Technology evolves quickly, and I continuously adapt my process to keep up. From AI-assisted workflows to modern no-code and low-code tools, I improve efficiency without sacrificing quality or control. The goal is not to follow trends, but to use new technologies thoughtfully when they create real value.',
    thumb: '[Future-Oriented]',
    thumbClass: 'is-4',
  },
]
---

<section id="capabilities" class="section_capabilities">
  <div class="capabilities_component">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-medium">
          <div class="capabilities_wrapper">
            <div class="capabilities_list">

              <!-- Sticky header -->
              <div class="capabilities_top-wrapper">
                <div class="capabilities_header-wrapper">
                  <div class="capabilities_header-left">
                    <h2
                      class="heading-style-h1"
                      data-anim="blur-fade"
                    >Capabilities</h2>
                    <div
                      class="text-color-grey"
                      data-anim="blur-fade"
                      data-anim-delay="0.1"
                    >Complex system. Clear thinking.</div>
                  </div>
                </div>
                <div class="spacer-xlarge"></div>

                <!-- First item inside top-wrapper -->
                <div class="capabilities_item">
                  <div class="capabilities_item-left-content">
                    <h3 class="capabilities_heading"
                      data-anim="blur-fade"
                    >{items[0].heading}</h3>
                  </div>
                  <div class="capabilities_item-right-wrapper"
                    data-anim="blur-fade"
                    data-anim-delay="0.1"
                  >
                    <p>{items[0].body}</p>
                  </div>
                  <div class={`capabilities_item-thumb ${items[0].thumbClass}`}>{items[0].thumb}</div>
                </div>
              </div>

              <!-- Remaining sticky items — siblings of top-wrapper -->
              {items.slice(1).map(({ heading, body, thumb, thumbClass }) => (
                <div class="capabilities_item">
                  <div class="capabilities_item-left-content">
                    <h3 class="capabilities_heading"
                      data-anim="blur-fade"
                    >{heading}</h3>
                  </div>
                  <div class="capabilities_item-right-wrapper"
                    data-anim="blur-fade"
                    data-anim-delay="0.1"
                  >
                    <p>{body}</p>
                  </div>
                  <div class={`capabilities_item-thumb ${thumbClass}`}>{thumb}</div>
                </div>
              ))}

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
