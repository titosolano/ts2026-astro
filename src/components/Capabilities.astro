---
const items = [
  {
    heading: 'Design-Led Thinking',
    body: 'My background in branding, visual design, and UX allows me to contribute well before execution begins. I enjoy understanding business goals, user needs, and project constraints to help shape the right direction from the start. Whether defining strategy, structure, content, or interface design, I believe the best digital experiences emerge when design decisions are informed by both business objectives and user needs.',
    thumb: '[Design-Led]',
    thumbClass: '',
  },
  {
    heading: 'Precision Implementation',
    body: 'With more than ten years of experience building digital products across different industries and project scales, I\'ve developed a strong appreciation for quality execution. I focus on creating reliable, maintainable, and high-performing solutions while paying close attention to the details that shape the overall experience. Regardless of the platform or technology involved, my goal is to build according to modern standards and best practices.',
    thumb: '[Precision]',
    thumbClass: 'is-2',
  },
  {
    heading: 'Connected Systems',
    body: 'Digital experiences rarely exist in isolation. I enjoy connecting websites with external platforms, APIs, databases, automations, and internal workflows to create systems that work together seamlessly. The objective is not only to add functionality, but also to reduce friction, simplify operations, and create solutions that are easier to manage over time.',
    thumb: '[Connected]',
    thumbClass: 'is-3',
  },
  {
    heading: 'Future-Oriented Workflows',
    body: 'Technology evolves quickly, and I enjoy exploring better ways to design, build, and solve problems. From AI-assisted workflows and rapid prototyping to modern no-code and low-code tools, I continuously adapt my process to improve efficiency without sacrificing quality, creativity, or control. The goal is not to follow trends, but to make thoughtful use of new technologies when they create real value.',
    thumb: '[Future-Oriented]',
    thumbClass: 'is-4',
  },
]
---

<section id="capabilities" class="section_capabilities">
  <div class="capabilities_component">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-medium">
          <div class="capabilities_wrapper">
            <div class="capabilities_list">

              <!-- Sticky header -->
              <div class="capabilities_top-wrapper">
                <div class="capabilities_header-wrapper">
                  <div class="capabilities_header-left">
                    <h2
                      class="heading-style-h1"
                      data-anim="blur-fade"
                    >Capabilities</h2>
                    <div
                      class="text-color-grey"
                      data-anim="blur-fade"
                      data-anim-delay="0.1"
                    >Complex system. Clear thinking.</div>
                  </div>
                </div>
                <div class="spacer-xlarge"></div>

                <!-- First item inside top-wrapper -->
                <div class="capabilities_item">
                  <div class="capabilities_item-left-content">
                    <h3 class="capabilities_heading"
                      data-anim="blur-fade"
                    >{items[0].heading}</h3>
                  </div>
                  <div class="capabilities_item-right-wrapper"
                    data-anim="blur-fade"
                    data-anim-delay="0.1"
                  >
                    <p>{items[0].body}</p>
                  </div>
                  <div class={`capabilities_item-thumb ${items[0].thumbClass}`}>{items[0].thumb}</div>
                </div>
              </div>

              <!-- Remaining sticky items — siblings of top-wrapper -->
              {items.slice(1).map(({ heading, body, thumb, thumbClass }) => (
                <div class="capabilities_item">
                  <div class="capabilities_item-left-content">
                    <h3 class="capabilities_heading"
                      data-anim="blur-fade"
                    >{heading}</h3>
                  </div>
                  <div class="capabilities_item-right-wrapper"
                    data-anim="blur-fade"
                    data-anim-delay="0.1"
                  >
                    <p>{body}</p>
                  </div>
                  <div class={`capabilities_item-thumb ${thumbClass}`}>{thumb}</div>
                </div>
              ))}

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
