---
const stats = [
  { number: '10+', label: 'Years', body: 'Building digital experiences' },
  { number: '200+', label: 'Projects', body: 'Across multiple industries' },
  { number: 'Global Reach', label: 'Collaborating across industries and international markets', body: '' },
]
---

<section id="about" class="section_layout7">
  <div class="about-grid_component">

    <div class="about-grid_top-content">
      <div class="padding-global">
        <div class="container-large">
          <div class="about-grid_content">

            <!-- Left: bio -->
            <div class="about-grid_content-left">
              <div class="about-grid_content-left-top">
                <div class="about-grid_item-content">

                  <h2 class="heading-tag_component" data-anim="blur-fade">
                    <div class="heading-tag_wrapper">
                      <img loading="lazy" src="/images/dots-icon.svg" alt="" class="heading-tag_icon" />
                      <div class="text-color-green">About</div>
                    </div>
                  </h2>

                  <div class="spacer-small"></div>

                  <div class="text-style-balance" data-anim="blur-fade" data-anim-delay="0.1">
                    <h2 class="heading-style-h3">Where design and execution evolve together.</h2>
                  </div>

                  <div class="spacer-small"></div>

                  <div class="max-width-medium" data-anim="blur-fade" data-anim-delay="0.3">
                    <p class="text-size-regular">I began my career in product design, developing skills in 3D design, product development methodologies, and a structural way of thinking about how things are made. That foundation shaped the way I approach digital work today, with a balance between design sensitivity, technical reasoning, and attention to how systems are built.</p>
                    <br />
                    <p class="text-size-regular">My path evolved through branding, visual design, and UX/UI, which naturally led into interface design and digital execution. Webflow became a key part of that evolution, opening the door to development in a practical and visual way, and gradually expanding my understanding of CSS, JavaScript, integrations, APIs, and automation workflows.</p>
                    <br />
                    <p class="text-size-regular">Today I work through hybrid processes where strategy, design, development, and automation come together. I combine creative and technical skills to design and build digital experiences that are visually strong, technically reliable, and carefully executed.</p>
                  </div>

                </div>
              </div>
            </div>

            <!-- Right -->
            <div class="about-grid_right-side">

              <!-- Top row: stats | empty spacer -->
              <div class="about-grid_right-top">
                <div class="about-grid_stats-wrapper">
                  {stats.map(({ number, label, body }, i) => (
                    <div class="about-grid_item" data-anim="fade" data-anim-delay={String(i * 0.08)}>
                      <div class="about-grid_stat-number">{number}</div>
                      <div class="about-grid_item-text-wrapper">
                        <h3 class="heading-style-label">{label}</h3>
                        {body && <><div class="spacer-xsmall"></div><p>{body}</p></>}
                      </div>
                    </div>
                  ))}
                </div>
                <!-- Intentional empty spacer — aligns portrait below stats -->
                <div class="about-grid_phrase-right"></div>
              </div>

              <!-- Bottom row: portrait | quote -->
              <div class="about-grid_right">

                <div class="about-grid_right-left-wrapper">
                  <div class="layout-grid_image-wrapper">
                    <img
                      src="/images/test-photo-v3_1test-photo-v3.avif"
                      loading="lazy"
                      width="600"
                      height="600"
                      alt="Black and white profile of a bald man with a mustache wearing a high-collared shirt."
                      class="layout7_profile-image"
                      data-anim="blur-fade"
                      data-anim-start="top 90%"
                    />
                  </div>
                </div>

                <div class="about-grid_phrase-right is-phrase">
                  <div class="about-grid_phrase-wrapper">
                    <div class="about-grid_main-wrapper">
                      <div class="about-grid_content-top" data-anim="blur-fade" data-anim-start="top 98%">
                        <img src="/images/quote.svg" loading="lazy" width="70" height="56" alt="" class="icon-1x1-small" />
                        <div class="spacer-small"></div>
                        <div>"Good digital experiences are not only designed visually, they are structured, connected, and carefully built from the inside out."</div>
                      </div>
                      <div class="spacer-small"></div>
                      <div class="about-grid_name-wrapper">
                        <div class="about-grid_name-list" data-anim="blur-fade" data-anim-start="top 98%">
                          <div class="about-grid_person-name">Tito Solano</div>
                          <div class="about-grid_person-title">Digital systems designer</div>
                        </div>
                      </div>
                    </div>
                    <div class="about-grid_phrase-line"></div>
                    <div class="about-grid_phrase-line is-right"></div>
                  </div>
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Background image -->
    <div class="about-grid_background">
      <img src="/images/bakground-about.avif" loading="lazy" alt="" class="about-grid_background-image" />
      <div class="about-grid_background-overlay"></div>
    </div>

  </div>
</section>
