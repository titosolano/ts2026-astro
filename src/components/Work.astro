  {
    title: 'Transbiotech',
    slug: 'transbiotech',
    featured: true,
    description: 'A corporate website focused on creating a distinctive and memorable digital experience through layout and interaction design. The project explored unconventional transitions and visual storytelling while maintaining clarity and usability.',
    credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.',
    url: 'https://www.transbio.tech/',
    industry: 'Biotechnology',
    year: 2022,
    role: 'Lead Developer & Webflow',
    challenge: 'The challenge was translating a distinctive visual concept into a functional Webflow experience, using layered curtain-style transitions to create an engaging corporate website without compromising usability.',
    approach: 'The website was developed in Webflow using native interactions, with careful layering, sequencing, and responsive implementation to create a distinctive curtain-style transition system.',
    keyFeatures: [
      'Webflow interactions system',
      'Advanced interface layering',
      'Unique curtain-style transitions',
      'Responsive implementation',
      'Rapid Webflow development',
    ],
    coverImage: '/images/Transbiotech-small.jpg',
    coverImageAlt: 'Transbiotech website mockup.',
  },
  {
    title: 'Wikky',
    slug: 'wikky',
    featured: true,
    description: 'A brand and website redesign for a consulting business focused on Monday.com solutions. The project involved leading the rebranding direction, creating the visual assets, developing the website, and producing the motion elements needed to give the experience a more polished and modern presence.',
    url: 'https://www.wikky.io/',
    industry: 'Business Consulting',
    year: 2025,
    role: 'Brand Designer, Webflow Developer & Motion Designer',
    challenge: 'The main challenge was to create a simple but attractive website that could communicate the brand clearly, support the client\'s positioning around Monday.com products, and feel modern without overcomplicating the experience.',
    approach: 'The website was developed in Webflow with a lightweight structure, CMS-driven content management, GSAP interactions, Lottie animations, and SwiperJS components. The result is a clean, fast, and easy-to-manage site that gives the brand a stronger and more current digital presence.',
    keyFeatures: [
      'Original brand and website redesign',
      'Webflow development',
      'Lightweight and fast implementation',
      'GSAP-powered interactions',
      'Lottie animations',
      'SwiperJS components',
      'CMS structure for simple content updates',
    ],
    coverImage: '/images/Wikky.jpg',
    coverImageAlt: 'Wikky website mockup.',
  },
]

let projects: Project[] = FALLBACK_PROJECTS

try {
  const data = await client?.fetch(`
    *[_type == "project"] | order(order asc) {
      title,
      "slug": slug.current,
      featured,
      "description": pt::text(description),
      credit,
      url,
      industry,
      year,
      "role": role,
      "challenge": pt::text(challenge),
      "approach": pt::text(approach),
      keyFeatures,
      "coverImage": coverImage.asset->url,
      "coverImageAlt": coalesce(coverImageAlt, title),
    }
  `)
  if (data?.length) projects = data
} catch {
  // Sanity not configured — fallback data is used
}
---

<section id="work" class="section_work">
  <SectionHeader
    label="Work"
    subtitle="Complex systems. Clear thinking."
    description="Selected projects where design, logic, and execution align."
  />
  <WorkSlider client:load projects={projects} />
</section>
