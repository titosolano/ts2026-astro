---
import { client } from '../lib/sanity'
import SectionHeader from './SectionHeader.astro'
import WorkSlider from './WorkSlider.tsx'
import type { Project } from './WorkSlider.tsx'
import { FALLBACK_PROJECTS, PROJECTS_QUERY } from '../data/projects'

let projects: Project[] = FALLBACK_PROJECTS

try {
  const data = await client?.fetch(PROJECTS_QUERY)
  if (data?.length) projects = data
} catch {
  // Sanity not configured — fallback data is used
}
---

<section id="work" class="section_work">
  <SectionHeader
    label="Work"
    subtitle="Selected projects, built with care and intention."
    description="Over the years, I've had the opportunity to work on a wide range of projects alongside talented teams, founders, and agencies. Here are a few that I particularly enjoyed building. Each one reflects its own challenges, ideas, and goals, as well as the collaboration, care, and problem-solving that helped bring it to life."
  />
  <WorkSlider client:load projects={projects} />
</section>
