---
import { client } from '../../lib/sanity'
import { FALLBACK_PROJECTS, PROJECTS_QUERY } from '../../data/projects'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import ProjectCard from '../../components/ProjectCard.tsx'
import Footer from '../../components/Footer.astro'
import type { Project } from '../../components/ProjectCard.tsx'

export async function getStaticPaths() {
  try {
    const data = await client?.fetch(PROJECTS_QUERY)
    if (data?.length) {
      return data.map((project: Project) => ({
        params: { slug: project.slug },
        props: { project },
      }))
    }
  } catch {}

  return FALLBACK_PROJECTS.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

const { project } = Astro.props as { project: Project }
---

<BaseLayout title={`${project.title} — Tito Solano`}>
  <div class="page-wrapper">
    <Nav variant="sticky" />
    <main class="main-wrapper">
      <section class="section_case-study">
        <ProjectCard project={project} standalone />
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
