export async function getStaticPaths() {
  // getStaticPaths runs in isolation — fetch and return projects as props
  // so the page component doesn't need a second fetch
  const FALLBACK: Project[] = [
    { title: 'La Citadelle', slug: 'la-citadelle', featured: true, description: 'A premium Webflow website for La Citadelle de Québec.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.lacitadelle.qc.ca/', industry: 'Museum / Cultural Institution', year: 2024, role: 'Lead Webflow Developer & Integration Developer', challenge: 'Bringing a clean and elegant design to life through subtle but meaningful interactions.', approach: 'Developed with a focus on layout precision, responsive behavior, and scroll-based animation.', keyFeatures: ['GSAP and Lottie animations', 'CMS structure for content management', 'Responsive implementation', 'Clean, elegant experience'], coverImage: '/images/mockup1.jpg', coverImageAlt: 'La Citadelle website mockup.' },
    { title: 'Morrin Centre Interactive Archive', slug: 'morrin-centre', featured: true, description: 'An interactive archive experience designed for touch-screen use.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.morrin.app/', industry: 'Cultural Institution / Digital Archive', year: 2024, role: 'Lead Developer & Webflow', challenge: 'Building a searchable database experience in a touch-screen context.', approach: 'Developed with Webflow connected to Xano as the backend database.', keyFeatures: ['App-like archive experience', 'Touch-screen usability', 'Xano database integration', 'Bilingual content support'], coverImage: '/images/morrin.avif', coverImageAlt: "Registre d'Écrou screen." },
    { title: 'Jeune Chambre De Commerce De Québec', slug: 'jccq', featured: true, description: 'A dynamic Webflow website with expressive layouts and member-centered experience.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.jccq.qc.ca/', industry: 'Professional Network / Community', year: 2024, role: 'Lead Developer & Webflow', challenge: 'Translating a bold, animated design into a scalable website with app-like functionality.', approach: 'Led development of website structure, animations, CMS, and technical integrations.', keyFeatures: ['Advanced web app functionality', 'Voting and promotion systems', 'Xano, Wized, and Make integrations'], coverImage: '/images/jccq-2.avif', coverImageAlt: 'JCCQ website mockup.' },
    { title: 'Safari Condo', slug: 'safari-condo', featured: true, description: 'A Webflow website with rich layering and scroll-based storytelling.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.safaricondo.com/', industry: 'Automotive / Travel', year: 2024, role: 'Lead Developer & Webflow', challenge: 'Translating a distinctive visual design into a responsive and animated website.', approach: 'Built using SVG, GSAP, Lottie, and Swiper.js to preserve design intent.', keyFeatures: ['Scroll-based route animation', 'Custom SVG elements', 'GSAP and Lottie integrations'], coverImage: '/images/safaricondo.avif', coverImageAlt: 'Safari Condo website mockup.' },
    { title: 'Wendake', slug: 'wendake', featured: true, description: 'A large-scale community platform for the Huron-Wendat Nation.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.wendake.ca/', industry: 'Culture & Community', year: 2025, role: 'Lead Developer & Webflow', challenge: 'Organizing a large content ecosystem intuitively for visitors and residents.', approach: 'Structured CMS architecture for broad content ecosystem management.', keyFeatures: ['Large-scale CMS', 'Custom favorites system', 'Foxy e-commerce'], coverImage: '/images/Wendake-Small.jpg', coverImageAlt: 'Wendake website mockup.' },
    { title: 'Transbiotech', slug: 'transbiotech', featured: true, description: 'A corporate website with distinctive curtain-style transitions.', credit: 'Webflow development by Tito Solano as part of Uroboro.ca development team.', url: 'https://www.transbio.tech/', industry: 'Biotechnology', year: 2022, role: 'Lead Developer & Webflow', challenge: 'Translating a distinctive visual concept into a functional Webflow experience.', approach: 'Developed using Webflow native interactions with careful layering and sequencing.', keyFeatures: ['Webflow interactions system', 'Curtain-style transitions', 'Responsive implementation'], coverImage: '/images/Transbiotech-small.jpg', coverImageAlt: 'Transbiotech website mockup.' },
    { title: 'Wikky', slug: 'wikky', featured: true, description: 'A brand and website redesign for a Monday.com consulting business.', url: 'https://www.wikky.io/', industry: 'Business Consulting', year: 2025, role: 'Brand Designer, Webflow Developer & Motion Designer', challenge: 'Creating a modern website that communicates the brand clearly.', approach: 'Lightweight Webflow build with CMS, GSAP, and Lottie animations.', keyFeatures: ['Brand redesign', 'GSAP interactions', 'Lottie animations', 'CMS structure'], coverImage: '/images/Wikky.jpg', coverImageAlt: 'Wikky website mockup.' },
  ]

  try {
    const { createClient } = await import('@sanity/client')
    const projectId = process.env.PUBLIC_SANITY_PROJECT_ID
    if (projectId) {
      const sanity = createClient({ projectId, dataset: process.env.PUBLIC_SANITY_DATASET ?? 'production', apiVersion: '2024-01-01', useCdn: true })
      const data = await sanity.fetch(`
        *[_type == "project"] | order(order asc) {
          title, "slug": slug.current, featured,
          "description": pt::text(description), credit, url, industry, year, role,
          "challenge": pt::text(challenge), "approach": pt::text(approach), keyFeatures,
          "coverImage": coverImage.asset->url, "coverImageAlt": coalesce(coverImageAlt, title),
        }
      `)
      if (data?.length) {
        return data.map((project: Project) => ({ params: { slug: project.slug }, props: { project } }))
      }
    }
  } catch {}

  return FALLBACK.map(project => ({ params: { slug: project.slug }, props: { project } }))
}

const { project } = Astro.props as { project: Project }
---

<BaseLayout title={`${project.title} — Tito Solano`}>
  <div class="page-wrapper">
    <Nav />
    <main class="main-wrapper">
      <section class="use-case-template_component">
        <ProjectCard project={project} standalone />
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
